{
  "mcpServers": {
    "aws-core": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.core-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "aws-lambda": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.lambda-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "leetcoach-dev",
        "AWS_REGION": "us-east-1"
      }
    },
    "aws-cloudwatch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.cloudwatch-logs-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "leetcoach-dev",
        "AWS_REGION": "us-east-1"
      }
    }
  }
}