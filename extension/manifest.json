{
  "manifest_version": 3,
  "name": "LeetCoach",
  "version": "1.0.0",
  "description": "AI coaching sidebar for LeetCode - hints, feedback, and DSA guidance powered by Claude.",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://leetcode.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "LeetCoach"
  },

  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open LeetCoach sidebar"
    }
  }
}
